model Comment {
  comment_id String        @id @default(uuid())
  content    String        @db.Text
  author_id  String
  post_id    String
  postId     Post          @relation(fields: [post_id], references: [post_id], onDelete: Cascade)
  parent_id  String?
  parentId   Comment?      @relation("commentReply", fields: [parent_id], references: [comment_id], onDelete: Cascade)
  Replies    Comment[]     @relation("commentReply")
  status     CommentStatus @default(APPROVE)
  createAt   DateTime      @default(now())
  updateAt   DateTime      @updatedAt

  @@index([author_id])
  @@index([post_id])
  @@map("comments")
}

enum CommentStatus {
  REJECT
  APPROVE
}

enum Status {
  DRAFT
  PUBLISHED
  APPROVE
}